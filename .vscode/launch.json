{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GDScript: Launch Project",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "address": "127.0.0.1",
            "port": 6007,
            "debug_collisions": false,
            "debug_paths": false,
            "debug_navigation": false,
            "additional_options": ""
        },
        {
            "name": "GDScript: Launch Current Scene",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "scene": "current",
            "address": "127.0.0.1",
            "port": 6007,
            "debug_collisions": false,
            "debug_paths": false,
            "debug_navigation": false,
            "additional_options": ""
        },
        {
            "name": "GDScript: Launch Main Menu",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "address": "127.0.0.1",
            "port": 6007,
            "additional_options": "res://scenes/ui/main_menu.tscn"
        },
        {
            "name": "GDScript: Launch Map (Skip Menu)",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "address": "127.0.0.1",
            "port": 6007,
            "debug_collisions": true,
            "debug_paths": false,
            "debug_navigation": false,
            "additional_options": "res://scenes/map/map.tscn"
        },
        {
            "name": "GDScript: Attach to Running Project",
            "type": "godot",
            "request": "attach",
            "address": "127.0.0.1",
            "port": 6007
        }
    ]
}
